# === AI Chat Providers (fallback chain) ===
# Set at least one. Ordered by priority:
#   1. Groq (fastest, most generous free tier)
#   2. Cloudflare Workers AI (needs both CF_API_TOKEN + CF_ACCOUNT_ID)
#   3. OpenRouter (fallback)

# ── Groq ────────────────────────────────────
# Get key: https://console.groq.com/keys
# Model list: https://console.groq.com/docs/models
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile   # optional, default: llama-3.3-70b-versatile

# ── OpenRouter ──────────────────────────────
# Get key: https://openrouter.ai/keys
# Free models: https://openrouter.ai/models?q=free
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=openai/gpt-oss-120b:free  # optional

# ── AI Chat limit ───────────────────────────
# Max messages per user per day (public, accessible in browser)
# PUBLIC_AI_CHAT_LIMIT=5

# ── Typesense Search ────────────────────────
# Get these from https://cloud.typesense.org (free tier)
# Public env vars (accessible in browser — use search-only key!)
# PUBLIC_TYPESENSE_HOST=xxx.typesense.net
# PUBLIC_TYPESENSE_PORT=443
# PUBLIC_TYPESENSE_PROTOCOL=https
# PUBLIC_TYPESENSE_SEARCH_KEY=your_search_only_key
# PUBLIC_TYPESENSE_COLLECTION=pages

# Server-only (for indexing script, keep secret!)
# TYPESENSE_API_KEY=your_admin_api_key
