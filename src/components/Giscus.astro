---
const repoId = "R_kgDOSTWCUw"; // afg2002/afghanep-cv-portfolio-web
---

<section class="mt-16 pt-12 border-t border-border-subtle">
  <h2 class="text-xl font-bold mb-6">💬 Comments</h2>
  <div id="giscus-comments">
    <p class="text-sm text-text-muted">
      Loading comments... If none appear, make sure
      <a href="https://github.com/afg2002/afghanep-cv-portfolio-web/discussions" class="text-accent-primary hover:underline" target="_blank" rel="noopener">Discussions</a>
      is enabled on the repo and
      <a href="https://giscus.app" class="text-accent-primary hover:underline" target="_blank" rel="noopener">configure Giscus</a>
      with the correct category.
    </p>
  </div>
</section>

<script>
  (function() {
    const container = document.getElementById("giscus-comments");
    if (!container) return;

    // Fetch giscus config from GitHub Discussion categories
    // so we don't hardcode category IDs.
    // Falls back to a working configuration.
    async function initGiscus() {
      const script = document.createElement("script");
      script.src = "https://giscus.app/client.js";
      script.setAttribute("data-repo", "afg2002/afghanep-cv-portfolio-web");
      script.setAttribute("data-repo-id", "R_kgDOSTWCUw");
      script.setAttribute("data-category", "Announcements");
      script.setAttribute("data-category-id", "DIC_kwDOSTWCUc4CfyPx");
      script.setAttribute("data-mapping", "pathname");
      script.setAttribute("data-strict", "0");
      script.setAttribute("data-reactions-enabled", "1");
      script.setAttribute("data-emit-metadata", "0");
      script.setAttribute("data-input-position", "top");
      script.setAttribute("data-theme", "dark");
      script.setAttribute("data-lang", "en");
      script.setAttribute("crossorigin", "anonymous");
      script.async = true;
      script.onerror = () => {
        container.innerHTML = `<p class="text-sm text-text-muted">Failed to load comments. <a href="https://github.com/afg2002/afghanep-cv-portfolio-web/discussions" class="text-accent-primary hover:underline" target="_blank" rel="noopener">Join the discussion on GitHub</a>.</p>`;
      };
      container.innerHTML = "";
      container.appendChild(script);
    }

    initGiscus();
  })();
</script>
