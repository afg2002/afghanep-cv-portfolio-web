              <span class="text-sm text-text-primary">Home</span>
              <span class="ml-auto text-[10px] font-mono text-text-muted">Ctrl+H</span>
            </a>
            <a href="/#about" class="cmd-item flex items-center gap-3 px-5 py-3 hover:bg-bg-elevated transition-colors no-underline" data-cmd="about">
              <svg class="w-4 h-4 text-accent-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              <span class="text-sm text-text-primary">About</span>
            </a>
            <a href="/#skills" class="cmd-item flex items-center gap-3 px-5 py-3 hover:bg-bg-elevated transition-colors no-underline" data-cmd="skills">
              <svg class="w-4 h-4 text-accent-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
              <span class="text-sm text-text-primary">Skills</span>
            </a>
            <a href="/#experience" class="cmd-item flex items-center gap-3 px-5 py-3 hover:bg-bg-elevated transition-colors no-underline" data-cmd="experience">
