            <a href="/#education" class="cmd-item flex items-center gap-3 px-5 py-3 hover:bg-bg-elevated transition-colors no-underline" data-cmd="education">
              <svg class="w-4 h-4 text-accent-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"/></svg>
              <span class="text-sm text-text-primary">Education</span>
            </a>
            <a href="/#contact" class="cmd-item flex items-center gap-3 px-5 py-3 hover:bg-bg-elevated transition-colors no-underline" data-cmd="contact">
              <svg class="w-4 h-4 text-accent-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <span class="text-sm text-text-primary">Contact</span>
            </a>
            <a href="/blog" class="cmd-item flex items-center gap-3 px-5 py-3 hover:bg-bg-elevated transition-colors no-underline" data-cmd="blog">
              <svg class="w-4 h-4 text-accent-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
              <span class="text-sm text-text-primary">Blog</span>
              <span class="ml-auto text-[10px] font-mono text-text-muted">Ctrl+B</span>
            </a>
          </div>
          <div class="border-t border-border-subtle py-1">
            <div class="px-5 py-2 text-[10px] font-mono text-text-muted uppercase tracking-wider">Social</div>
            <a href="https://github.com/afg2002" target="_blank" rel="noopener" class="cmd-item flex items-center gap-3 px-5 py-3 hover:bg-bg-elevated transition-colors no-underline" data-cmd="github">
              <svg class="w-4 h-4 text-text-secondary shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
              <span class="text-sm text-text-primary">GitHub</span>
              <span class="ml-auto text-[10px] font-mono text-text-muted">Ctrl+G</span>
            </a>
            <a href="https://www.linkedin.com/in/afghan-eka-pangestu/" target="_blank" rel="noopener" class="cmd-item flex items-center gap-3 px-5 py-3 hover:bg-bg-elevated transition-colors no-underline" data-cmd="linkedin">
              <svg class="w-4 h-4 text-text-secondary shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              <span class="text-sm text-text-primary">LinkedIn</span>
            </a>
            <a href="mailto:afghanekapangestu@gmail.com" class="cmd-item flex items-center gap-3 px-5 py-3 hover:bg-bg-elevated transition-colors no-underline" data-cmd="email">
              <svg class="w-4 h-4 text-text-secondary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <span class="text-sm text-text-primary">Email</span>
            </a>
          </div>
          <div class="border-t border-border-subtle py-1">
            <div class="px-5 py-2 text-[10px] font-mono text-text-muted uppercase tracking-wider">Actions</div>
            <a href="/cv-afghan-eka-pangestu.pdf" target="_blank" class="cmd-item flex items-center gap-3 px-5 py-3 hover:bg-bg-elevated transition-colors no-underline" data-cmd="cv">
              <svg class="w-4 h-4 text-accent-secondary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              <span class="text-sm text-text-primary">Download CV</span>
              <span class="ml-auto text-[10px] font-mono text-text-muted">Ctrl+D</span>
            </a>
          </div>
        </div>

        <!-- Pagefind search results (hidden by default) -->
        <div id="cmd-search-results" class="hidden"></div>

        <!-- Loading state -->
        <div id="cmd-loading" class="hidden py-10 text-center">
          <div class="w-6 h-6 mx-auto border-2 border-accent-primary border-t-transparent rounded-full animate-spin"></div>
        </div>

        <!-- Empty state -->
        <div id="cmd-empty" class="hidden py-12 text-center">
          <p class="text-sm text-text-muted">No results found.</p>
        </div>
      </div>

      <!-- Footer -->
      <div id="cmd-footer" class="px-5 py-3 border-t border-border-subtle text-xs text-text-muted flex items-center justify-between">
        <span id="cmd-footer-left">🔍 Navigate</span>
        <span>Powered by <a href="https://pagefind.app" target="_blank" rel="noopener" class="text-accent-primary hover:underline">Pagefind</a></span>
      </div>
    </div>
  </div>
</div>

<!-- Load Pagefind at runtime -->
<script is:inline src="/pagefind/pagefind.js"></script>

<script>
  (function() {
    var palette = document.getElementById("cmd-palette");
    var input = document.getElementById("cmd-input");
    var backdrop = document.getElementById("cmd-backdrop");
    var commandsContainer = document.getElementById("cmd-commands");
    var searchResults = document.getElementById("cmd-search-results");
    var loadingEl = document.getElementById("cmd-loading");
    var emptyEl = document.getElementById("cmd-empty");
    var footerEl = document.getElementById("cmd-footer");
    var footerLeft = document.getElementById("cmd-footer-left");

    var pagefindLoaded = false;

    function escapeHtml(text) {
      if (!text) return "";
      var div = document.createElement("div");
      div.textContent = text || "";
      return div.innerHTML;
    }

    function highlightMatch(text, query) {
      if (!text || !query) return escapeHtml(text);
      var escaped = escapeHtml(text);
      var regex = new RegExp("(" + query.replace(/[.*+?^${}()|[\]\\]/g, "\\$&") + ")", "gi");
      return escaped.replace(regex, '<mark class="bg-accent-primary/20 text-accent-primary rounded px-0.5">$1</mark>');
    }

    function togglePalette() {
      var isOpen = palette.classList.contains("hidden");
      palette.classList.toggle("hidden", !isOpen);
      if (isOpen) {
        input.value = "";
        showCommands();
        input.focus();
      }
    }

    function showCommands() {
      commandsContainer.classList.remove("hidden");
      searchResults.classList.add("hidden");
      searchResults.innerHTML = "";
      loadingEl.classList.add("hidden");
      emptyEl.classList.add("hidden");
      footerLeft.textContent = "🔍 Navigate";
    }

    function showSearchResults() {
      commandsContainer.classList.add("hidden");
      searchResults.classList.remove("hidden");
      loadingEl.classList.add("hidden");
    }

    function showLoading() {
      commandsContainer.classList.add("hidden");
      searchResults.classList.add("hidden");
      searchResults.innerHTML = "";
      loadingEl.classList.remove("hidden");
      emptyEl.classList.add("hidden");
    }

    function showEmpty() {
      commandsContainer.classList.add("hidden");
      searchResults.classList.add("hidden");
      searchResults.innerHTML = "";
      loadingEl.classList.add("hidden");
      emptyEl.classList.remove("hidden");
    }

    // Filter commands client-side for instant feedback
    input.addEventListener("input", function() {
      var q = input.value.trim().toLowerCase();

      if (q.length === 0) {
        showCommands();
        return;
      }

      if (q.length < 2) {
        // Only filter commands
        var visible = false;
        document.querySelectorAll("#cmd-commands .cmd-item").forEach(function(item) {
          var cmdText = (item.getAttribute("data-cmd") || "").toLowerCase();
          var spanText = (item.querySelector("span")?.textContent || "").toLowerCase();
          var match = cmdText.includes(q) || spanText.includes(q);
          item.classList.toggle("hidden", !match);
          if (match) visible = true;
        });
        commandsContainer.classList.remove("hidden");
        searchResults.classList.add("hidden");
        searchResults.innerHTML = "";
        loadingEl.classList.add("hidden");
        emptyEl.classList.add("hidden");

        if (!visible) {
          emptyEl.classList.remove("hidden");
        }
        return;
      }

      // Query length >= 2: search Pagefind
      debouncedPagefindSearch(q);
    });

    var debounceTimer = null;
    var abortController = null;

    function debouncedPagefindSearch(q) {
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function() { pagefindSearch(q); }, 200);
    }

    async function pagefindSearch(q) {
      showLoading();

      // Wait for Pagefind if not loaded yet
      if (!pagefindLoaded && typeof window.pagefind !== "undefined") {
        pagefindLoaded = true;
      }

      if (!window.pagefind) {
        // Pagefind hasn't loaded yet, wait a bit
        if (window.pagefind) pagefindLoaded = true;
        var retries = 0;
        while (!window.pagefind && retries < 30) {
          await new Promise(function(r) { setTimeout(r, 100); });
          retries++;
        }
        if (window.pagefind) pagefindLoaded = true;
      }

      if (!window.pagefind) {
        showCommands();
        return;
      }

      try {
        var search = await window.pagefind.search(q);
        var hits = search.results;

        if (!hits || hits.length === 0) {
          showEmpty();
          footerLeft.textContent = 'No results for "' + q + '"';
          return;
        }

        // Load up to 20 results
        var loadedResults = await Promise.all(hits.slice(0, 20).map(function(r) { return r.data(); }));

        footerLeft.textContent = hits.length + " result" + (hits.length > 1 ? "s" : "") + ' for "' + q + '"';
        showSearchResults();

        var frag = document.createDocumentFragment();
        for (var i = 0; i < loadedResults.length; i++) {
          var hit = loadedResults[i];
          var hitTitle = (hit.meta && hit.meta.title) || "Untitled";
          var hitUrl = hit.url || (hit.meta && hit.meta.url) || "/";
          var hitExcerpt = hit.excerpt || (hit.meta && hit.meta.description) || "";
          var isBlog = hitUrl.indexOf("/blog/") !== -1;

          var itemEl = document.createElement("a");
          itemEl.href = hitUrl;
          itemEl.className = "flex items-start gap-3 px-5 py-3.5 hover:bg-bg-elevated transition-colors no-underline border-b border-border-subtle last:border-b-0";
          itemEl.innerHTML =
            '<span class="text-base mt-0.5 shrink-0">' + (isBlog ? "📝" : "📄") + '</span>' +
            '<div class="min-w-0">' +
            '<p class="text-sm font-medium text-text-primary">' + highlightMatch(hitTitle, q) + '</p>' +
            (hitExcerpt ? '<div class="text-xs text-text-muted mt-1 leading-relaxed line-clamp-2">' + hitExcerpt + '</div>' : "") +
            '<div class="text-[10px] font-mono text-text-muted/60 mt-1">' + (isBlog ? "Blog" : "Page") + "</div>" +
            '</div>';
          frag.appendChild(itemEl);
        }
        searchResults.innerHTML = "";
        searchResults.appendChild(frag);
      } catch (err) {
        console.warn("[cmd] Pagefind error:", err);
        showCommands();
      }
    }

    // Close on backdrop click
    backdrop.addEventListener("click", togglePalette);

    // Global keyboard shortcuts
    document.addEventListener("keydown", function(e) {
      if (e.key === "Escape" && !palette.classList.contains("hidden")) {
        togglePalette();
      }
      if ((e.ctrlKey || e.metaKey) && e.key === "k") {
        e.preventDefault();
        togglePalette();
      }
      if ((e.ctrlKey || e.metaKey) && e.key === "h") {
        e.preventDefault();
        window.location.href = "/#home";
      }
      if ((e.ctrlKey || e.metaKey) && e.key === "b") {
        e.preventDefault();
        window.location.href = "/blog";
      }
      if ((e.ctrlKey || e.metaKey) && e.key === "g") {
        e.preventDefault();
        window.open("https://github.com/afg2002", "_blank");
      }
      if ((e.ctrlKey || e.metaKey) && e.key === "d") {
        e.preventDefault();
        window.open("/cv-afghan-eka-pangestu.pdf", "_blank");
      }
    });

    // Expose toggle globally for header button
    window.__toggleSearch = togglePalette;
  })();
</script>