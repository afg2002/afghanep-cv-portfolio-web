---
---

<!-- Command Palette Modal -->
<div id="cmd-palette" class="fixed inset-0 z-[200] hidden" role="dialog" aria-modal="true" aria-label="Command Palette">
  <!-- Backdrop -->
  <div id="cmd-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <!-- Panel -->
  <div class="relative max-w-2xl mx-auto mt-[12vh] px-4">
    <div class="bg-bg-secondary border border-border-subtle rounded-2xl shadow-2xl shadow-black/50 overflow-hidden">
      <!-- Input -->
      <div class="flex items-center gap-3 px-5 py-4 border-b border-border-subtle">
        <svg class="w-5 h-5 text-text-muted shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          id="cmd-input"
          type="text"
          placeholder="Search pages, blog posts & commands..."
          class="flex-1 bg-transparent text-text-primary text-lg placeholder-text-muted focus:outline-none"
          autocomplete="off"
          autofocus
        />
        <div class="hidden sm:flex items-center gap-1">
          <kbd class="px-2 py-1 text-[11px] font-mono text-text-muted bg-bg-elevated border border-border-subtle rounded-md">ESC</kbd>
        </div>
      </div>

      <!-- Results area -->
      <div id="cmd-results" class="max-h-[55vh] overflow-y-auto">
        <!-- Default: show command sections -->
        <div id="cmd-commands">
          <!-- Navigation -->
          <div class="py-1">
            <div class="px-5 py-2 text-[10px] font-mono text-text-muted uppercase tracking-wider">Navigation</div>
