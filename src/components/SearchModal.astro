<div id="search-modal" class="fixed inset-0 z-[100] hidden" role="dialog" aria-modal="true" aria-label="Search">
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <!-- Panel -->
  <div class="relative max-w-2xl mx-auto mt-[15vh] px-4">
    <div class="bg-bg-secondary border border-border-subtle rounded-2xl shadow-2xl shadow-black/50 overflow-hidden">
      <!-- Input -->
      <div class="flex items-center gap-3 px-5 py-4 border-b border-border-subtle">
        <svg class="w-5 h-5 text-text-muted shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="Search pages & blog posts..."
          class="flex-1 bg-transparent text-text-primary text-lg placeholder-text-muted focus:outline-none"
          autocomplete="off"
          autofocus
        />
        <kbd class="hidden sm:inline-flex px-2 py-1 text-[11px] font-mono text-text-muted bg-bg-elevated border border-border-subtle rounded-md">ESC</kbd>
      </div>

      <!-- Results -->
      <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2">
        <p class="text-sm text-text-muted text-center py-8">Start typing to search...</p>
      </div>

      <!-- Footer -->
      <div id="search-footer" class="hidden px-5 py-3 border-t border-border-subtle text-xs text-text-muted flex items-center justify-between">
        <span>🔍 <span id="result-count"></span></span>
        <span>Powered by <a href="https://para.io" target="_blank" rel="noopener" class="text-accent-primary hover:underline">Para</a></span>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    var modal = document.getElementById("search-modal");
    var input = document.getElementById("search-input");
    var results = document.getElementById("search-results");
    var backdrop = document.getElementById("search-backdrop");
    var footer = document.getElementById("search-footer");
    var resultCount = document.getElementById("result-count");

    // Para config - hardcoded for client-side search
    var PARA_APP_ID = "cv-portfolio";
    var PARA_ENDPOINT = "https://para.io";

    function escapeHtml(text) {
      if (!text) return "";
      var div = document.createElement("div");
      div.textContent = text;
      return div.innerHTML;
    }

    function toggleSearch() {
      var isOpen = modal.classList.contains("hidden");
      modal.classList.toggle("hidden", isOpen);
      if (!isOpen) {
        input.value = "";
        results.innerHTML = '<p class="text-sm text-text-muted text-center py-8">Start typing to search...</p>';
        footer.classList.add("hidden");
        input.focus();
      }
    }

    backdrop.addEventListener("click", toggleSearch);
    document.addEventListener("keydown", function(e) {
      if (e.key === "Escape" && !modal.classList.contains("hidden")) {
        toggleSearch();
      }
      if ((e.ctrlKey || e.metaKey) && e.key === "k") {
        e.preventDefault();
        toggleSearch();
      }
    });

    // Expose toggle globally for header button
    window.__toggleSearch = toggleSearch;

    var debounceTimer = null;
    var abortController = null;

    input.addEventListener("input", function() {
      if (debounceTimer) clearTimeout(debounceTimer);
      var q = input.value.trim();

      if (abortController) {
        abortController.abort();
        abortController = null;
      }

      if (q.length < 2) {
        results.innerHTML = '<p class="text-sm text-text-muted text-center py-8">Type at least 2 characters to search...</p>';
        footer.classList.add("hidden");
        return;
      }

      debounceTimer = setTimeout(function() {
        results.innerHTML = '<div class="flex justify-center py-8"><div class="w-6 h-6 border-2 border-accent-primary border-t-transparent rounded-full animate-spin"></div></div>';

        abortController = new AbortController();
        var signal = abortController.signal;

        var searchUrl = PARA_ENDPOINT + "/v1/search";
        var url = searchUrl + "?q=" + encodeURIComponent(q) + "&type=page,blogpost&appId=" + PARA_APP_ID + "&limit=20";

        fetch(url, { signal: signal })
          .then(function(res) {
            if (!res.ok) throw new Error("HTTP " + res.status);
            return res.json();
          })
          .then(function(data) {
            var hits = (data && data.results) || [];

            if (hits.length === 0) {
              results.innerHTML = '<p class="text-sm text-text-muted text-center py-8">No results found for "<strong class="text-text-secondary">' + escapeHtml(q) + '</strong>"</p>';
              return;
            }

            footer.classList.remove("hidden");
            resultCount.textContent = hits.length + " result" + (hits.length > 1 ? "s" : "") + ' for "' + escapeHtml(q) + '"';

            var frag = document.createDocumentFragment();
            for (var i = 0; i < hits.length; i++) {
              var hit = hits[i];
              var title = hit.title || hit.name || "Untitled";
              var desc = hit.description || "";
              var pageUrl = hit.url || hit.uri || "/";
              var isBlog = pageUrl.indexOf("/blog/") !== -1;

              var itemEl = document.createElement("a");
              itemEl.href = pageUrl;
              itemEl.className = "block p-4 rounded-xl hover:bg-bg-elevated transition-colors no-underline group";
              itemEl.innerHTML =
                '<div class="flex items-start gap-3">' +
                '<span class="text-base mt-0.5 shrink-0">' + (isBlog ? "📝" : "📄") + '</span>' +
                '<div class="min-w-0">' +
                '<p class="text-sm font-medium text-text-primary group-hover:text-accent-primary transition-colors">' + escapeHtml(title) + '</p>' +
                (desc ? '<div class="text-xs text-text-muted mt-1 leading-relaxed line-clamp-2">' + escapeHtml(desc) + '</div>' : "") +
                '<div class="text-[10px] font-mono text-text-muted/60 mt-1">' + (isBlog ? "Blog" : "Page") + " · " + pageUrl + '</div>' +
                '</div></div>';
              frag.appendChild(itemEl);
            }
            results.innerHTML = "";
            results.appendChild(frag);
          })
          .catch(function(err) {
            if (err.name === "AbortError") return;
            console.warn("[search] Error:", err);
            results.innerHTML = '<p class="text-sm text-text-muted text-center py-8">Search error. Please try again.</p>';
          });
      }, 300);
    });
  })();
</script>