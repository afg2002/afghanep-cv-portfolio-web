<div id="search-modal" class="fixed inset-0 z-[100] hidden" role="dialog" aria-modal="true" aria-label="Search">
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <!-- Panel -->
  <div class="relative max-w-2xl mx-auto mt-[15vh] px-4">
    <div class="bg-bg-secondary border border-border-subtle rounded-2xl shadow-2xl shadow-black/50 overflow-hidden">
      <!-- Input -->
      <div class="flex items-center gap-3 px-5 py-4 border-b border-border-subtle">
        <svg class="w-5 h-5 text-text-muted shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="Search pages & blog posts..."
          class="flex-1 bg-transparent text-text-primary text-lg placeholder-text-muted focus:outline-none"
          autocomplete="off"
          autofocus
        />
        <kbd class="hidden sm:inline-flex px-2 py-1 text-[11px] font-mono text-text-muted bg-bg-elevated border border-border-subtle rounded-md">ESC</kbd>
      </div>

      <!-- Results -->
      <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2">
        <p class="text-sm text-text-muted text-center py-8">Start typing to search...</p>
      </div>

      <!-- Footer -->
      <div id="search-footer" class="hidden px-5 py-3 border-t border-border-subtle text-xs text-text-muted flex items-center justify-between">
        <span>🔍 <span id="result-count"></span></span>
        <span>Powered by <a href="https://github.com/nextapps-de/flexsearch" target="_blank" rel="noopener" class="text-accent-primary hover:underline">FlexSearch</a></span>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    // ── DOM refs ──
    const modal = document.getElementById("search-modal")!;
    const input = document.getElementById("search-input") as HTMLInputElement;
    const results = document.getElementById("search-results")!;
    const backdrop = document.getElementById("search-backdrop")!;
    const footer = document.getElementById("search-footer")!;
    const resultCount = document.getElementById("result-count")!;

    // ── Open/close ──
    (window as any).__toggleSearch = function() {
      const isOpen = !modal.classList.contains("hidden");
      modal.classList.toggle("hidden", isOpen);
      if (!isOpen) {
        input.value = "";
        results.innerHTML = `<p class="text-sm text-text-muted text-center py-8">Start typing to search...</p>`;
        footer.classList.add("hidden");
        input.focus();
      }
    };

    backdrop.addEventListener("click", () => (window as any).__toggleSearch());
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal.classList.contains("hidden")) {
        (window as any).__toggleSearch();
      }
      if ((e.ctrlKey || e.metaKey) && e.key === "k") {
        e.preventDefault();
        (window as any).__toggleSearch();
      }
    });

    // ── FlexSearch index ──
    let index: any = null;

    async function initIndex() {
      if (index) return index;

      const [{ Index: FlexIndex }, pageData] = await Promise.all([
        import("flexsearch").then(m => ({ Index: m.default })),
        fetch("/search-index.json").then(r => r.json()).catch(() => []),
      ]);

      index = new FlexIndex({
        preset: "match",
        tokenize: "forward",
        context: true,
      });

      // Add all pages to index
      for (let i = 0; i < pageData.length; i++) {
        const page = pageData[i];
        const text = `${page.title} ${page.description} ${page.content}`.toLowerCase();
        index.add(i, text);

        // Store page data by index for retrieval
        (index as any)._pages = (index as any)._pages || {};
        (index as any)._pages[i] = page;
      }

      return index;
    }

    // ── Search ──
    let debounceTimer: number | null = null;

    input.addEventListener("input", () => {
      if (debounceTimer) clearTimeout(debounceTimer);
      const q = input.value.trim();
      if (q.length < 2) {
        results.innerHTML = `<p class="text-sm text-text-muted text-center py-8">Type at least 2 characters to search...</p>`;
        footer.classList.add("hidden");
        return;
      }

      debounceTimer = window.setTimeout(async () => {
        results.innerHTML = `<div class="flex justify-center py-8"><div class="w-6 h-6 border-2 border-accent-primary border-t-transparent rounded-full animate-spin"></div></div>`;

        try {
          const idx = await initIndex();
          if (!idx || !idx._pages) {
            results.innerHTML = `<p class="text-sm text-text-muted text-center py-8">Search index not found. Run 'npm run build' first.</p>`;
            return;
          }

          // Search — FlexSearch returns IDs directly
          const ids: number[] = idx.search(q, { limit: 20 });

          if (ids.length === 0) {
            results.innerHTML = `<p class="text-sm text-text-muted text-center py-8">No results found for "<strong class="text-text-secondary">${escapeHtml(q)}</strong>"</p>`;
            return;
          }

          footer.classList.remove("hidden");
          resultCount.textContent = `${ids.length} result${ids.length > 1 ? "s" : ""} for "${escapeHtml(q)}"`;

          const frag = document.createDocumentFragment();
          for (const id of ids) {
            const page = (idx as any)._pages[id];
            if (!page) continue;

            const isBlog = page.url?.includes("/blog/");
            const excerpt = page.description || page.content?.slice(0, 120) || "";

            const itemEl = document.createElement("a");
            itemEl.href = page.url || "/";
            itemEl.className = "block p-4 rounded-xl hover:bg-bg-elevated transition-colors no-underline group";
            itemEl.innerHTML = `
              <div class="flex items-start gap-3">
                <span class="text-base mt-0.5 shrink-0">${isBlog ? "📝" : "📄"}</span>
                <div class="min-w-0">
                  <p class="text-sm font-medium text-text-primary group-hover:text-accent-primary transition-colors">${escapeHtml(page.title || "Untitled")}</p>
                  ${excerpt ? `<div class="text-xs text-text-muted mt-1 leading-relaxed line-clamp-2">${escapeHtml(excerpt)}</div>` : ""}
                  <div class="text-[10px] font-mono text-text-muted/60 mt-1">${isBlog ? "Blog" : "Page"} · ${page.url || "/"}</div>
                </div>
              </div>
            `;
            frag.appendChild(itemEl);
          }
          results.innerHTML = "";
          results.appendChild(frag);
        } catch (e: any) {
          console.warn("[search] Error:", e);
          results.innerHTML = `<p class="text-sm text-text-muted text-center py-8">Search error. Please try again.</p>`;
        }
      }, 300);
    });

    function escapeHtml(text: string): string {
      if (!text) return "";
      const div = document.createElement("div");
      div.textContent = text;
      return div.innerHTML;
    }
  })();
</script>