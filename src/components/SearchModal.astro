<div id="search-modal" class="fixed inset-0 z-[100] hidden" role="dialog" aria-modal="true" aria-label="Search">
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <!-- Panel -->
  <div class="relative max-w-2xl mx-auto mt-[15vh] px-4">
    <div class="bg-bg-secondary border border-border-subtle rounded-2xl shadow-2xl shadow-black/50 overflow-hidden">
      <!-- Input -->
      <div class="flex items-center gap-3 px-5 py-4 border-b border-border-subtle">
        <svg class="w-5 h-5 text-text-muted shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="Search blog posts..."
          class="flex-1 bg-transparent text-text-primary text-lg placeholder-text-muted focus:outline-none"
          autocomplete="off"
          autofocus
        />
        <kbd class="hidden sm:inline-flex px-2 py-1 text-[11px] font-mono text-text-muted bg-bg-elevated border border-border-subtle rounded-md">ESC</kbd>
      </div>

      <!-- Results -->
      <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2">
        <p class="text-sm text-text-muted text-center py-8">Start typing to search...</p>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    // ── Open/close ──
    const modal = document.getElementById("search-modal")!;
    const input = document.getElementById("search-input") as HTMLInputElement;
    const results = document.getElementById("search-results")!;
    const backdrop = document.getElementById("search-backdrop")!;

    // Expose toggle globally for the header button
    (window as any).__toggleSearch = function() {
      const isOpen = !modal.classList.contains("hidden");
      modal.classList.toggle("hidden", isOpen);
      if (!isOpen) {
        input.value = "";
        results.innerHTML = `<p class="text-sm text-text-muted text-center py-8">Start typing to search...</p>`;
        input.focus();
      }
    };

    // Close handlers
    backdrop.addEventListener("click", () => (window as any).__toggleSearch());
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal.classList.contains("hidden")) {
        (window as any).__toggleSearch();
      }
      if ((e.ctrlKey || e.metaKey) && e.key === "k") {
        e.preventDefault();
        (window as any).__toggleSearch();
      }
    });

    // ── Pagefind search ──
    let pagefind: any = null;

    async function loadPagefind() {
      if (pagefind) return pagefind;
      try {
        // Load pagefind via dynamic script injection (avoids Vite build-time resolution)
        if (!document.querySelector('script[src*="pagefind.js"]')) {
          await new Promise((resolve, reject) => {
            const s = document.createElement("script");
            s.src = "/pagefind/pagefind.js";
            s.onload = resolve;
            s.onerror = () => reject(new Error("Failed to load pagefind"));
            document.head.appendChild(s);
          });
        }
        // Wait a tick for the module to register
        await new Promise(r => setTimeout(r, 100));
        // @ts-ignore
        pagefind = window.__pagefind__ || window.pagefind;
        return pagefind;
      } catch (e) {
        console.warn("[search] Pagefind load failed:", e);
        return null;
      }
    }

    let debounceTimer: number | null = null;

    input.addEventListener("input", () => {
      if (debounceTimer) clearTimeout(debounceTimer);
      const q = input.value.trim();
      if (q.length < 2) {
        results.innerHTML = `<p class="text-sm text-text-muted text-center py-8">Type at least 2 characters to search...</p>`;
        return;
      }

      debounceTimer = window.setTimeout(async () => {
        results.innerHTML = `<div class="flex justify-center py-8"><div class="w-5 h-5 border-2 border-accent-primary border-t-transparent rounded-full animate-spin"></div></div>`;

        const pf = await loadPagefind();
        if (!pf) {
          results.innerHTML = `<p class="text-sm text-text-muted text-center py-8">Search index not loaded. Try again later.</p>`;
          return;
        }

        const search = await pf.search(q);
        if (!search || !search.results || search.results.length === 0) {
          results.innerHTML = `<p class="text-sm text-text-muted text-center py-8">No results found for "<strong class="text-text-secondary">${escapeHtml(q)}</strong>"</p>`;
          return;
        }

        const frag = document.createDocumentFragment();
        for (const r of search.results.slice(0, 20)) {
          const data = await r.data();
          const excerpt = data.excerpt?.replace(/<mark>/g, '<mark class="text-accent-primary bg-accent-primary/10 rounded px-0.5">')
            .replace(/<\/mark>/g, "</mark>") || "";

          const item = document.createElement("a");
          item.href = data.url;
          item.className = "block p-4 rounded-xl hover:bg-bg-elevated transition-colors no-underline group";
          item.innerHTML = `
            <div class="flex items-start gap-3">
              <svg class="w-4 h-4 mt-1 text-text-muted shrink-0 group-hover:text-accent-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
              </svg>
              <div>
                <p class="text-sm font-medium text-text-primary group-hover:text-accent-primary transition-colors">${escapeHtml(data.meta?.title || data.url)}</p>
                <div class="text-xs text-text-muted mt-1 leading-relaxed line-clamp-2">${excerpt}</div>
              </div>
            </div>
          `;
          frag.appendChild(item);
        }
        results.innerHTML = "";
        results.appendChild(frag);
      }, 300);
    });

    function escapeHtml(text: string): string {
      const div = document.createElement("div");
      div.textContent = text;
      return div.innerHTML;
    }
  })();
</script>
